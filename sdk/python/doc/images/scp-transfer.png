		<style id="wp-custom-css">
			@media screen and (max-width: 720px) {
	
  /* center titles in in-post product blocks in blog posts on mobile */	
	.wp-block-woocommerce-single-product .wp-block-columns .wp-block-post-title {
		text-align: center;
	}
		
	/* add padding to single product blocks on blog posts on mobile */
	.wp-block-woocommerce-single-product .wp-block-columns {
		padding: 30px !important;
	}

	/* Set size of product title on mobile product subcategory pages */	
	.product-block-title {
		font-size: 20px !important;
	}
	/* Set padding inside blog subcategory blocks on category pages */
	.subcategory-block {
		padding: 25px !important;
	}
	/* Make page content wider on mobile */
	.page .ultp-block-wrapper {
		padding: 0px !important;
	}
	/* Make blog post content wider on mobile */
	.ultp-block-wrapper {
		padding: 10px !important;
	}
	/* Style "Proceed to Checkout" button on cart page on mobile */
	.wc-block-components-button__text {
		font-size: 20px !important;
		line-height: 25px !important;
	}
	.wc-block-cart__submit-container--sticky {
		display: none !important;
	}
	/* Arrange blog category and product category blocks on homepage and shop page so the image is on top on mobile */
  	.homepage-arduino-block {
    		flex-direction: column; 
    		align-items: flex-start;
  	}
  	.homepage-arduino-img {
   		 order: 1 !important;
  	}
  	.homepage-arduino-h2-p-b {
    		order: 2 !important;
  	}
  	.homepage-rpi-block {
    		flex-direction: column; 
    		align-items: flex-start;
  	}
  	.homepage-rpi-img {
    		order: 1 !important;
  	}
  	.homepage-rpi-h2-p-b {
    		order: 2 !important;
  	}
  	.homepage-electronics-block {
    		flex-direction: column; 
    		align-items: flex-start;
  	}
  	.homepage-electronics-img {
    		order: 1 !important;
  	}
  	.homepage-electronics-h2-p-b {
    		order: 2 !important;
  	}	
  	.shoppage-ampPCBs-block {
   		flex-direction: column; 
    		align-items: flex-start;
  	}
  	.shoppage-ampPCBs-img {
    		order: 1 !important;
  	}
  	.shoppage-ampPCBs-h2-p-b {
   		order: 2 !important;
  	}	
	/* Adjust font size of headings and paragraphs on mobile */
    	.page h1 {
        	font-size: 50px !important;
    	}
	.page h2 {
        	font-size: 30px !important;
    	}
	.page h3 {
        	font-size: 25px;
    	}
	.page p {
		font-size: 20px !important;
	}
	.wp-container-content-1 {
		font-size: 22px !important;
	}
	.wp-block-post-author-name {
		font-size: 42px !important;
		line-height: 50px !important;
	}	
	.category-intro-text {
		font-size: 20px !important;
	}
}

/* Make the cart items total separated from the cart icon in the header */
.ast-icon-shopping-cart{
	display: flex;
}

/* Change font size inside header search bar, make width smaller, and align right */
.wp-block-search__input::placeholder{
	font-size: 18px;
}
.wp-block-search__input{
	max-width: 50%;
	margin-left: auto;
}

/* Change size of blog and shop logo in footer */
.wp-image-443937{
	width: 75%; 
	height: auto;
}
.wp-image-443936{
	width: 75%; 
	height: auto;
}

/* Make parts list tables on product pages scroll right on mobile */
.scrollable-table{
	overflow-x: auto;
}

/* Make consent label on contact form align left */
legend._form-label{
	padding-left:0 !important;
}

/* Style product review stars on product tables in product category pages */
.product-table-review-stars{
	color: #ff9966;
	text-align: center;
}

/* Style product specification tables on product pages */
.product-spec-table {
  width: 75%;
	border: 1px solid #3A3A3A;
}
.product-spec-table th, .product-spec-table td {
        border: 1px solid #3A3A3A;
        padding: 10px;
}

/* Center sidebar on tablets and contain to same width */
@media (min-width: 720px) and (max-width: 1080px) {
	 .ultp-sidebar-right { 
	 	margin: auto;
	 	max-width: 60%;
	 }
	.wp-block-search__input {
		font-size: 20px;
	}
}

/* Change text size of inline code and code blocks */
code {
	font-size: 18px;
}

/* Add spacing below YouTube embeds, images, and code blocks */
.wp-block-embed__wrapper, .wp-block-image, .wp-block-code {
	margin-bottom: 40px;
}

/* Change color of "Says" text in blog post comment meta to site body text default */
.ultp-builder-comment-reply .comment-author .says{
	color: #4B4F58;
}

/* Put blog post comment input box at top of comments and set gap between comments */
.ultp-block-comments {
        display: flex;
        flex-direction: column-reverse;
	gap: 80px;
}

/* Style search input form in sidebar */
.homePageSearchBar {
	max-width: 75%;
}
.wp-block-search__inside-wrapper {
	margin: auto;
	min-width: 100%;
}
.wp-block-search__input {
	border-color: #757575 !important;
	border-radius: 5px !important;
	background: #FAFAFA !important;
}
.sidebar-search-box{
	background: #FFFFFF;
	padding: 20px;
}
.wp-block-search__button {
	border-radius: 5px !important;
}

/* Set the background color gradient on all pages and search page */
.search {
	background: linear-gradient(0.25turn, #42A5F5, #FFEE58);  
}
.page {
	background: linear-gradient(0.25turn, #42A5F5, #FFEE58);  
}
.author {
	background: linear-gradient(0.25turn, #42A5F5, #FFEE58);  
}
.post-type-archive-product {
	background: linear-gradient(0.25turn, #42A5F5, #FFEE58);  
}

/* Customize text on order received page */
.woocommerce-thankyou-order-received:after {
    content: " You will receive a confirmation email shortly.";
}

body.woocommerce-order-received .wp-block-heading {
    display: none;
}

/* Change the font size of captions in the gallery at the end of the LM4562 preamp article */
.wp-element-caption {
	font-size: 16px;
}

/* Format parts list table in LM4562 preamp article */
.postid-444739 .product-spec-table {
	font-size: 12px;
	width: auto; 
	line-height: 1.5em;
}

.postid-444739 .product-spec-table td, th {
	padding: 5px; 
}
		</style>
